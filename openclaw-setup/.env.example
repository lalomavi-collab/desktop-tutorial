# ── Tailscale ────────────────────────────────────────────────────
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# Recommended: use a reusable + ephemeral key tagged with "tag:container"
TS_AUTHKEY=tskey-auth-XXXXXXXXXXXX

# ── OpenClaw – AI Provider (at least one required) ──────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXX
# OPENAI_API_KEY=sk-XXXXXXXXXXXX
# OPENROUTER_API_KEY=sk-or-XXXXXXXXXXXX

# ── OpenClaw – Authentication ───────────────────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme-use-a-strong-password
OPENCLAW_GATEWAY_TOKEN=generate-a-random-token-here
