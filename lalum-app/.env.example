# LALUM app client env. Copy to .env.local and fill in.
# When Supabase vars are absent, the app runs in a self-contained demo mode:
# auth and portal forms work locally without a network backend.

# Supabase (custom domain recommended in production, e.g. https://api.lalumapp.com)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: a Calendly scheduling link. When set, the portal embeds Calendly
# instead of the built-in day/time picker (e.g. https://calendly.com/your-org/intro).
VITE_CALENDLY_URL=
