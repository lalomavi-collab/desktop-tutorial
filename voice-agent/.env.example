# Copy to .env and fill in. Never commit real secrets.

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_JUDGE_MODEL=claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=512

# ── Deepgram (STT) ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
DEEPGRAM_LANGUAGE=en
DEEPGRAM_ENDPOINTING_MS=300

# ── ElevenLabs (TTS) ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5

# ── Supabase / Postgres (state + pgvector RAG) ────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# ── Telephony / escalation ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
HUMAN_OPERATOR_NUMBER=+972000000000
N8N_WEBHOOK_URL=

# ── Governance ────────────────────────────────────────────────────────────────
COMPLIANCE_MIN_SCORE=0.60
COMPANY_NAME=LALUM
